# Copy to .env and fill in. Never commit .env.

# OpenAI API key for the CLI / OpenAI Agents SDK runtime.
OPENAI_API_KEY=

# Use OpenAI Agents SDK for specialist tasks. Set false in tests or local mocks.
USE_OPENAI_AGENTS_SDK=true

# Privacy gate. PDF originals are never uploaded. When this is false, the
# pipeline refuses to send extracted user-PDF text chunks to OpenAI.
ALLOW_OPENAI_TEXT_UPLOAD=false

# Quality-first default routing. Override per stage if needed.
OPENAI_ISSUE_MODEL=gpt-5.5
OPENAI_NEWS_MODEL=gpt-5.4
OPENAI_SUMMARY_MODEL=gpt-5.4-mini
OPENAI_FACT_CHECK_MODEL=gpt-5.5
OPENAI_CLASSIFIER_MODEL=gpt-5.4-mini
OPENAI_LAYOUT_MODEL=gpt-5.5

# Optional: override default directories.
# OUTPUT_DIR=./data/output
# STATE_DIR=./data/extracted

# Optional: log level (DEBUG / INFO / WARNING / ERROR).
# LOG_LEVEL=INFO
